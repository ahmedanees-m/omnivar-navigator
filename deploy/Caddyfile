# Caddy reverse proxy — TLS + basic auth in front of the OmniVar stack (Phase 9).
# The VM has a private IP (10.30.x.x); reach the UI via an SSH tunnel for dev, or
# expose on the institutional network behind this auth. No PHI in logs.
# Replace the host and the bcrypt hash (generate: `caddy hash-password`).
{$OMNIVAR_HOST:localhost} {
	encode gzip
	# Geneticist/MDT review UI
	handle /api/* {
		uri strip_prefix /api
		reverse_proxy api:8000
	}
	handle {
		reverse_proxy ui:80
	}
	basic_auth {
		# user  <bcrypt-hash>   (set via `caddy hash-password`; never commit a real hash)
		{$OMNIVAR_USER:mdt} {$OMNIVAR_PASSWORD_HASH}
	}
	log {
		output stdout
		# do not log request bodies (no PHI)
	}
}
